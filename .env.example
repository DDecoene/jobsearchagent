# Copy to .env and fill in. .env is gitignored.

# --- VDAB Open Services (https://developer.vdab.be/openservices/) ---
# Register an account, subscribe to the "Vacatures" API, create an
# application, and copy the key + exact endpoint details from the portal.
VDAB_API_KEY=
VDAB_API_BASE=https://api.vdab.be
# Check the portal docs for the exact path of the vacancy search endpoint:
VDAB_SEARCH_PATH=/services/openservices/vacatures
# How the key is sent. Portal docs will say; common variants:
#   Authorization: Bearer <key>   -> VDAB_AUTH_HEADER=Authorization, VDAB_AUTH_PREFIX="Bearer "
#   X-Api-Key: <key>              -> VDAB_AUTH_HEADER=X-Api-Key, VDAB_AUTH_PREFIX=
VDAB_AUTH_HEADER=Authorization
VDAB_AUTH_PREFIX="Bearer "
# Comma-separated search terms (NL + EN), e.g.:
VDAB_SEARCH_TERMS=ERP,business systems,procesverbetering,applicatiebeheerder

# --- Agent settings ---
JOBSEARCH_DB=data/jobs.sqlite3
JOBSEARCH_PROFILE=PROFILE.md
JOBSEARCH_BACKFILL_DAYS=14
